## Public client-side config (embedded into bundle)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Google Sign-In (Expo Go)
# Create an OAuth client ID in Google Cloud Console that can be used with Expo Go.
# This value is used to obtain a Google `id_token`, which is then exchanged with the backend.
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Google Sign-In (web)
# This value is used when `npm run web` is run, enabling dev machines
# without native development tooling to use Google Sign-In.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com
